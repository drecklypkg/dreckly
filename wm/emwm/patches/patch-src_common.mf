$NetBSD: patch-src_common.mf,v 1.2 2024/12/08 14:00:28 vins Exp $

* Use standard CFLAGS and LDFLAGS.

--- src/common.mf.orig	2025-03-04 12:54:58.000000000 +0000
+++ src/common.mf
@@ -31,7 +31,7 @@ emwm: $(mwm_objs) $(wsm_objs)
 	$(CC) $(LDFLAGS) $(LIBDIRS) -o $@ $(mwm_objs) $(wsm_objs) $(SYSLIBS)
 
 .depend:
-	$(CC) -MM $(INCDIRS) $(mwm_objs:.o=.c) $(wsm_objs:.o=.c) > $@
+	$(CC) -MM $(CFLAGS) $(INCDIRS) $(mwm_objs:.o=.c) $(wsm_objs:.o=.c) > $@
 
 .PHONY: clean install common_install
 
